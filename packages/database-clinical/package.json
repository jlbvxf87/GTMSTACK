{
  "name": "@gtmstack/database-clinical",
  "version": "0.0.0",
  "private": true,
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./types": "./src/types.ts",
    "./queries/*": "./src/queries/*.ts"
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "gen:types": "supabase gen types typescript --project-id $SUPABASE_CLINICAL_PROJECT_ID > src/types.ts"
  },
  "dependencies": {
    "@supabase/ssr": "^0.4.0",
    "@supabase/supabase-js": "^2.45.0"
  },
  "devDependencies": {
    "@gtmstack/config": "workspace:*",
    "typescript": "^5.4.0"
  }
}
