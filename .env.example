# =========================================================================
# GTMStack env template. See docs/CLAUDE.md for architectural decisions.
# Never commit a populated .env file. Per-app .env.local files override these.
# =========================================================================

# --- App URLs ---
NEXT_PUBLIC_MARKETING_URL=http://localhost:3000
NEXT_PUBLIC_OPERATOR_URL=http://localhost:3001
NEXT_PUBLIC_STOREFRONT_URL=http://localhost:3002
NEXT_PUBLIC_PROVIDER_URL=http://localhost:3003
NEXT_PUBLIC_ADMIN_URL=http://localhost:3004
NEXT_PUBLIC_ROOT_DOMAIN=gtmstack.local
NEXT_PUBLIC_STOREFRONT_ROOT_DOMAIN=gtmstack.shop

# --- Supabase CORE (operators, brands, products, orders, AI, analytics) ---
NEXT_PUBLIC_SUPABASE_CORE_URL=
NEXT_PUBLIC_SUPABASE_CORE_ANON_KEY=
SUPABASE_CORE_SERVICE_ROLE_KEY=

# --- Supabase CLINICAL (PHI — separate project, hard isolation) ---
NEXT_PUBLIC_SUPABASE_CLINICAL_URL=
NEXT_PUBLIC_SUPABASE_CLINICAL_ANON_KEY=
SUPABASE_CLINICAL_SERVICE_ROLE_KEY=
SUPABASE_CLINICAL_ENCRYPTION_KEY=

# --- Stripe Connect (standard commerce) ---
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_CONNECT_CLIENT_ID=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# --- CarePlug Pay (high-risk categories: peptides, hormones, controlled) ---
CAREPLUG_PAY_API_KEY=
CAREPLUG_PAY_WEBHOOK_SECRET=

# --- AI (Anthropic primary) ---
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-opus-4-7

# --- Inngest (background jobs) ---
INNGEST_EVENT_KEY=
INNGEST_SIGNING_KEY=

# --- Resend (email) ---
RESEND_API_KEY=
RESEND_FROM_ADDRESS=hello@gtmstack.com

# --- Twilio (SMS) ---
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_MESSAGING_SERVICE_SID=

# --- Storage ---
SUPABASE_STORAGE_BUCKET=brand-assets
CLOUDFLARE_R2_ACCESS_KEY_ID=
CLOUDFLARE_R2_SECRET_ACCESS_KEY=
CLOUDFLARE_R2_BUCKET=

# --- Observability ---
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com
SENTRY_DSN=
SENTRY_AUTH_TOKEN=
AXIOM_TOKEN=
AXIOM_DATASET=
